PORT=3001
NODE_ENV=development

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
AI_MAX_HISTORY=14
# AI_CACHE_ENABLED=false ile kapatılır (varsayılan: açık)
# AI_CACHE_TTL_MS=3600000          # tek giriş TTL (ms, varsayılan 1 saat)
# AI_CACHE_TTL_HOURS=168           # kalıcı önbellek üst sınırı (varsayılan 7 gün)
# CACHE_VERSION=1                  # deploy'da artırın — tüm AI yanıt önbelleğini geçersiz kılar

WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
# Meta App Dashboard → App settings → Basic → App secret (webhook POST imza doğrulaması)
WHATSAPP_APP_SECRET=your-meta-app-secret
WHATSAPP_API_VERSION=v21.0

# Meta Messenger + Instagram DM (OAuth + /webhook/meta)
# META_APP_ID=your-meta-app-id
# META_APP_SECRET=your-meta-app-secret   # yoksa WHATSAPP_APP_SECRET kullanılır
# META_REDIRECT_URI=https://your-domain.example.com/api/v1/meta/oauth/callback
# META_VERIFY_TOKEN=                     # boşsa WHATSAPP_VERIFY_TOKEN
# META_API_VERSION=v21.0
# Personel talep bildirimi — Meta Business Manager'da onaylanan utility şablon adı ve dili
# WHATSAPP_STAFF_TICKET_TEMPLATE=staff_new_ticket
# WHATSAPP_STAFF_TICKET_TEMPLATE_LANG=tr

# Yerel geliştirme
CORS_ORIGIN=http://localhost:5173

# Baileys oturum dosyaları (Coolify Persistent Storage ile aynı yol)
# SESSIONS_DIR=/data/sessions

# Başvuru formu WhatsApp bildirimi
# PLATFORM_COMPANY_ID=uuid-of-platform-company-with-connected-whatsapp
# PLATFORM_SIGNUP_NOTIFY_PHONES=905338507761

# Admin e-posta bildirimleri (SMTP)
# SMTP_HOST=srvc87.trwww.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=waai-system@mekanizma.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=waai-system@mekanizma.com
# SMTP_FROM_NAME=Waai Sistem
# ADMIN_NOTIFY_EMAILS=info@mekanizma.com

# Canlı demo — bu şirkete gelen ilk mesajda özel karşılama metni gönderilir
# LIVE_DEMO_COMPANY_ID=uuid-of-live-demo-company-with-connected-whatsapp

DEMO_MODE=false

# Canlı mod (production / Coolify):
# DEMO_MODE=false
# VITE_DEMO_MODE=false (build-time — Coolify env'de Build Variable olarak işaretleyin)
# Supabase Auth → URL Configuration:
#   Site URL: https://your-domain.example.com
#   Redirect URLs: https://your-domain.example.com/**
