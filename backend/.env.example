PORT=3001
NODE_ENV=development

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_API_VERSION=v21.0

# WhatsApp Worker (Vercel + Railway) — docs/WHATSAPP-WORKER.md
# WHATSAPP_WORKER_URL=https://your-worker.railway.app
# WHATSAPP_WORKER_SECRET=your-32-char-secret

# Worker portu (sadece npm run worker)
# WORKER_PORT=3002

# Virgülle birden fazla origin: https://app.onrender.com,https://domain.com
CORS_ORIGIN=http://localhost:5173

# Render kalıcı disk (ücretli plan): SESSIONS_DIR=/var/data/sessions
# SESSIONS_DIR=

DEMO_MODE=false
