PORT=3001
NODE_ENV=development

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
AI_MAX_HISTORY=60

WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_API_VERSION=v21.0

# Yerel geliştirme
CORS_ORIGIN=http://localhost:5173

# Baileys oturum dosyaları (Render'da render.yaml otomatik ayarlar)
# SESSIONS_DIR=/opt/render/project/src/data/sessions

DEMO_MODE=false

# Canlı mod (production):
# DEMO_MODE=false
# VITE_DEMO_MODE=false (frontend/.env)
# Supabase Auth → URL Configuration:
#   Site URL: https://your-app.onrender.com
#   Redirect URLs: https://your-app.onrender.com/**
