PORT=3001
NODE_ENV=development

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
AI_MAX_HISTORY=14
# AI_CACHE_ENABLED=false ile kapatılır (varsayılan: açık)
# AI_CACHE_TTL_MS=3600000          # tek giriş TTL (ms, varsayılan 1 saat)
# AI_CACHE_TTL_HOURS=168           # kalıcı önbellek üst sınırı (varsayılan 7 gün)
# CACHE_VERSION=1                  # deploy'da artırın — tüm AI yanıt önbelleğini geçersiz kılar

WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_API_VERSION=v21.0

# Yerel geliştirme
CORS_ORIGIN=http://localhost:5173

# Baileys oturum dosyaları (Coolify Persistent Storage ile aynı yol)
# SESSIONS_DIR=/data/sessions

DEMO_MODE=false

# Canlı mod (production / Coolify):
# DEMO_MODE=false
# VITE_DEMO_MODE=false (build-time — Coolify env'de Build Variable olarak işaretleyin)
# Supabase Auth → URL Configuration:
#   Site URL: https://your-domain.example.com
#   Redirect URLs: https://your-domain.example.com/**
