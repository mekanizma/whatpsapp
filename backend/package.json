{
  "name": "whatsapp-ai-backend",
  "version": "1.0.0",
  "description": "AI WhatsApp SaaS Backend API",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "test:integration": "tsx src/scripts/test-appointment-integration.ts",
    "db:push": "cd .. && npx supabase db push --yes",
    "db:setup": "tsx src/scripts/setup-supabase.ts",
    "db:test": "tsx src/scripts/test-supabase.ts",
    "db:apply-invoice": "tsx src/scripts/apply-invoice-migration.ts",
    "prompts:reset": "tsx src/scripts/reset-prompts.ts",
    "prompts:cleanup": "tsx src/scripts/cleanup-prompts.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "@whiskeysockets/baileys": "6.7.22",
    "cors": "^2.8.5",
    "dejavu-fonts-ttf": "^2.37.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "openai": "^4.85.4",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "tinyld": "^1.3.4",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.5",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
