{
  "name": "whatsapp-ai-backend",
  "version": "1.0.0",
  "description": "AI WhatsApp SaaS Backend API",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:push": "cd .. && npx supabase db push --yes",
    "db:setup": "tsx src/scripts/setup-supabase.ts",
    "db:test": "tsx src/scripts/test-supabase.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "@whiskeysockets/baileys": "6.7.22",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "openai": "^4.85.4",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.5",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
