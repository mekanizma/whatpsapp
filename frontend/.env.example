VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Yerel geliştirme
VITE_API_URL=http://localhost:3001/api/v1

# Render / production: boş bırakın — otomatik /api/v1 (aynı domain)
# VITE_API_URL=

VITE_DEMO_MODE=false

# Canlı mod: VITE_DEMO_MODE=false ve gerçek Supabase anahtarları kullanın.
# Render build sırasında VITE_DEMO_MODE build-time'a gömülür — Render env'de false olmalı.
