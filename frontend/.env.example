VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Yerel geliştirme
VITE_API_URL=http://localhost:3001/api/v1

# Coolify / production: boş bırakın — otomatik /api/v1 (aynı domain)
# VITE_API_URL=

VITE_DEMO_MODE=false

# Production site URL (SEO: canonical, sitemap, Open Graph)
# VITE_SITE_URL=https://waai.mekanizma.com

# Platform WhatsApp (başvuru bildirimi ve landing chat bot)
# VITE_PLATFORM_WHATSAPP_PHONE=905338507761

# Canlı demo WhatsApp (onboarding "Canlı Demo" butonu)
# VITE_LIVE_DEMO_WHATSAPP_PHONE=905391172782

# Canlı mod: VITE_DEMO_MODE=false ve gerçek Supabase anahtarları kullanın.
# Coolify build sırasında VITE_* değişkenleri Build Variable olarak işaretlenmeli.
